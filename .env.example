# Django / DRF
DJANGO_SETTINGS_MODULE=config.settings
DJANGO_SECRET_KEY=change-me-in-local-env
JWT_SIGNING_KEY=change-me-in-local-env-use-at-least-32-characters
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
DJANGO_TIME_ZONE=UTC

# PostgreSQL
POSTGRES_DB=photo_classification
POSTGRES_USER=photo_app
POSTGRES_PASSWORD=photo_app_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://photo_app:photo_app_password@postgres:5432/photo_classification

# RabbitMQ / Celery
RABBITMQ_DEFAULT_USER=photo_app
RABBITMQ_DEFAULT_PASS=photo_app_password
RABBITMQ_DEFAULT_VHOST=photo_app
CELERY_BROKER_URL=amqp://photo_app:photo_app_password@rabbitmq:5672/photo_app
CELERY_RESULT_BACKEND=rpc://
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=true

# MinIO / S3-compatible object storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin-password
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin-password
S3_BUCKET_NAME=photo-submissions
S3_REGION_NAME=us-east-1
S3_USE_SSL=false

# Main service upload and classification controls
PHOTO_MAX_UPLOAD_BYTES=5242880
PHOTO_MIN_WIDTH=300
PHOTO_MIN_HEIGHT=300
PHOTO_MAX_WIDTH=5000
PHOTO_MAX_HEIGHT=5000
CLASSIFIER_URL=http://classifier:8001
CLASSIFIER_PROVIDER=rule_based
CLASSIFIER_TIMEOUT_SECONDS=5
CLASSIFIER_MAX_RETRIES=3
RABBITMQ_PUBLISH_MAX_ATTEMPTS=3
RETRY_BACKOFF_BASE_SECONDS=2
RETRY_BACKOFF_CAP_SECONDS=60
RETRY_BACKOFF_JITTER=true
WORKER_HEALTH_INCLUDE_QUEUE_DEPTH=false

# Optional future provider integration. Leave empty for credential-free rule-based mode.
MODEL_PROVIDER_API_KEY=
